---
import { getCollection } from 'astro:content';
import PageLayout from '../../../layouts/PageLayout.astro';
import PostArticle from '../../../components/PostArticle.astro';
import { altLangUrl } from '../../../i18n';

export async function getStaticPaths() {
  const posts = await getCollection('postsEn', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props:  { post },
  }));
}

const { post } = Astro.props;
const lang = 'en';
const altUrl = altLangUrl(lang, Astro.url.pathname, { pairSlug: post.data.pairSlug });
---

<PageLayout
  lang={lang}
  altUrl={altUrl}
  title={`${post.data.title} — INVERZ`}
  description={post.data.description}
  canonical={`https://inverz.hr/en/posts/${post.id}/`}
>
  <PostArticle lang={lang} post={post} />
</PageLayout>
