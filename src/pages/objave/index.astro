---
import PageLayout from '../../layouts/PageLayout.astro';
import PostsList from '../../components/PostsList.astro';
import { altLangUrl, t } from '../../i18n';

const lang = 'hr';
const altUrl = altLangUrl(lang, '/objave');
const d = t(lang);
---

<PageLayout
  lang={lang}
  altUrl={altUrl}
  title={`${d.postsPage.title} — INVERZ`}
  description={d.postsPage.sub}
  canonical="https://inverz.hr/objave/"
>
  <PostsList lang={lang} />
</PageLayout>
