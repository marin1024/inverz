---
import type { Lang } from '../i18n';
import { t } from '../i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const d = t(lang);
---

<section class="how" id="kako" aria-labelledby="how-title">
  <div class="inner">
    <header class="sec-head">
      <p class="t-eyebrow">{d.how.eyebrow}</p>
      <h2 id="how-title" class="t-h1 title">{d.how.title}</h2>
      <p class="sub">{d.how.sub}</p>
    </header>

    <ol class="steps">
      {d.how.steps.map((step) => (
        <li class="step">
          <span class="num">{step.num}</span>
          <div class="step-body">
            <h3 class="t-h3 step-title">{step.title}</h3>
            <p class="step-desc">{step.desc}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .how {
    padding: var(--space-9) 0;
  }
  .inner {
    max-width: var(--max-content);
    margin: 0 auto;
    padding: 0 var(--page-padding-x);
    display: flex;
    flex-direction: column;
    gap: var(--space-7);
  }
  .sec-head { display: flex; flex-direction: column; gap: var(--space-3); }
  .title { max-width: 18ch; }
  .sub { color: var(--color-text); max-width: 56ch; font-size: 1.0625rem; }

  .steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }
  .step {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-6) 0 0;
    border-top: var(--border-hairline) solid var(--color-border-subtle);
  }
  .num {
    font-family: var(--font-display);
    font-size: 0.875rem;
    letter-spacing: 0.14em;
    color: var(--color-muted);
  }
  .step-body { display: flex; flex-direction: column; gap: var(--space-3); }
  .step-desc { color: var(--color-text); font-size: 1rem; line-height: 1.6; max-width: 36ch; }

  @media (max-width: 720px) {
    .steps { grid-template-columns: 1fr; gap: var(--space-4); }
  }
</style>
