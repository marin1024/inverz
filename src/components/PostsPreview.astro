---
import { getCollection } from 'astro:content';
import type { Lang } from '../i18n';
import { t } from '../i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const d = t(lang);

const collectionName = lang === 'hr' ? 'postsHr' : 'postsEn';
const all = await getCollection(collectionName, ({ data }) => !data.draft);
const recent = all
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const postsBase = lang === 'hr' ? '/objave' : '/en/posts';
const dateLocale = lang === 'hr' ? 'hr-HR' : 'en-GB';

function formatDate(date: Date) {
  return new Intl.DateTimeFormat(dateLocale, {
    year: 'numeric', month: 'long', day: 'numeric',
  }).format(date);
}
---

<section class="posts" id="objave" aria-labelledby="posts-title">
  <div class="inner">
    <header class="sec-head">
      <div class="head-text">
        <p class="t-eyebrow">{d.postsSection.eyebrow}</p>
        <h2 id="posts-title" class="t-h1 title">{d.postsSection.title}</h2>
        <p class="sub">{d.postsSection.sub}</p>
      </div>
      <a href={`${postsBase}/`} class="all-link">
        {d.postsSection.viewAll} <span aria-hidden="true">→</span>
      </a>
    </header>

    {recent.length === 0 ? (
      <p class="empty">—</p>
    ) : (
      <ul class="grid">
        {recent.map((post) => (
          <li class="post">
            <a href={`${postsBase}/${post.id}/`} class="post-link">
              <span class="post-meta">
                <span class="post-cat">{post.data.category}</span>
                <span class="dot" aria-hidden="true">·</span>
                <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
              </span>
              <h3 class="t-h3 post-title">{post.data.title}</h3>
              <p class="post-desc">{post.data.description}</p>
              <span class="post-arrow" aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</section>

<style>
  .posts {
    padding: var(--space-9) 0;
  }
  .inner {
    max-width: var(--max-content);
    margin: 0 auto;
    padding: 0 var(--page-padding-x);
    display: flex;
    flex-direction: column;
    gap: var(--space-7);
  }
  .sec-head {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: end;
    gap: var(--space-5);
  }
  .head-text { display: flex; flex-direction: column; gap: var(--space-3); max-width: 60ch; }
  .title { max-width: 18ch; }
  .sub { color: var(--color-text); font-size: 1.0625rem; }

  .all-link {
    font-size: 0.9375rem;
    color: var(--color-fg);
    border-bottom: 0;
    padding-bottom: 0;
    white-space: nowrap;
    display: inline-flex;
    gap: 0.4em;
    align-items: center;
  }
  .all-link:hover { opacity: 0.7; }

  .grid {
    list-style: none;
    margin: 0; padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-5);
  }
  .post { margin: 0; padding: 0; }
  .post-link {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-6);
    border: var(--border-hairline) solid rgba(255, 255, 255, 0.10);
    background: var(--color-smoked);
    color: var(--color-fg);
    border-bottom: var(--border-hairline) solid rgba(255, 255, 255, 0.10);
    padding-bottom: var(--space-6);
    text-decoration: none;
    height: 100%;
    min-height: 220px;
    transition: border-color var(--transition-base);
  }
  .post-link:hover {
    opacity: 1;
    border-color: var(--color-border-strong);
  }
  .post-link:hover .post-arrow { transform: translateX(4px); }

  .post-meta {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-family: var(--font-body);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .post-cat { color: var(--color-text); }
  .dot { color: var(--color-border-strong); }
  .post-desc { color: var(--color-text); font-size: 0.9375rem; line-height: 1.55; }
  .post-arrow {
    align-self: flex-end;
    margin-top: auto;
    transition: transform var(--transition-base);
    font-size: 1.25rem;
    color: var(--color-fg);
  }

  .empty { color: var(--color-muted); }

  @media (max-width: 720px) {
    .sec-head { grid-template-columns: 1fr; align-items: start; }
  }
</style>
