---
import { render } from 'astro:content';
import type { Lang } from '../i18n';
import { t } from '../i18n';

interface Props {
  lang: Lang;
  /** Entry iz content collection-a — preda ga pages/[slug].astro. */
  // eslint-disable-next-line @typescript-eslint/no-explicit-any
  post: any;
}

const { lang, post } = Astro.props;
const d = t(lang);
const { Content } = await render(post);

const postsBase = lang === 'hr' ? '/objave' : '/en/posts';
const dateLocale = lang === 'hr' ? 'hr-HR' : 'en-GB';

const formattedDate = new Intl.DateTimeFormat(dateLocale, {
  year: 'numeric', month: 'long', day: 'numeric',
}).format(post.data.pubDate);
---

<article class="post-article">
  <div class="inner">
    <a class="back" href={`${postsBase}/`}>{d.postsPage.backToList}</a>

    <header class="post-head">
      <div class="meta">
        <span class="cat">{post.data.category}</span>
        <span class="dot" aria-hidden="true">·</span>
        <time datetime={post.data.pubDate.toISOString()}>{formattedDate}</time>
      </div>
      <h1 class="t-display title">{post.data.title}</h1>
      <p class="desc">{post.data.description}</p>
    </header>

    <div class="body">
      <Content />
    </div>
  </div>
</article>

<style>
  .post-article {
    padding: var(--space-9) 0;
  }
  .inner {
    max-width: 44rem;
    margin: 0 auto;
    padding: 0 var(--page-padding-x);
    display: flex;
    flex-direction: column;
    gap: var(--space-7);
  }
  .back {
    align-self: flex-start;
    font-size: 0.875rem;
    color: var(--color-muted);
    border-bottom: 0;
    padding-bottom: 0;
  }
  .back:hover { color: var(--color-fg); opacity: 1; }

  .post-head {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding-bottom: var(--space-5);
  }
  .meta {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-family: var(--font-body);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .cat { color: var(--color-text); }
  .dot { color: var(--color-border-strong); }
  .title {
    font-size: clamp(2.25rem, 6vw, 4rem);
    line-height: var(--lh-h1);
    letter-spacing: var(--ls-h1);
    max-width: 22ch;
  }
  .desc { color: var(--color-text); font-size: 1.125rem; line-height: 1.55; max-width: 44ch; }

  .body {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-text);
  }
  .body :global(h2) {
    font-family: var(--font-display);
    font-size: 1.75rem;
    line-height: 1.2;
    letter-spacing: -0.015em;
    color: var(--color-fg);
    margin-top: var(--space-7);
    margin-bottom: var(--space-3);
  }
  .body :global(h3) {
    font-family: var(--font-display);
    font-size: 1.25rem;
    line-height: 1.3;
    color: var(--color-fg);
    margin-top: var(--space-5);
    margin-bottom: var(--space-2);
  }
  .body :global(p)  { margin: 0 0 var(--space-4); }
  .body :global(ul),
  .body :global(ol) {
    padding-left: 1.5em;
    margin: 0 0 var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .body :global(li::marker) { color: var(--color-muted); }
  .body :global(strong) { color: var(--color-fg); font-weight: var(--fw-semi); }
  .body :global(hr) {
    border: 0;
    border-top: var(--border-hairline) solid var(--color-border-subtle);
    margin: var(--space-7) 0;
  }
  .body :global(a) {
    color: var(--color-fg);
    border-bottom: 1px solid var(--color-border-strong);
  }
  .body :global(a:hover) {
    border-bottom-color: var(--color-fg);
    opacity: 1;
  }
  .body :global(code) {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.92em;
    background: #0F0F0F;
    color: var(--color-fg);
    padding: 2px 6px;
    border-radius: var(--radius-xs);
  }
  .body :global(blockquote) {
    border-left: 2px solid var(--color-border-strong);
    padding-left: var(--space-4);
    color: var(--color-muted);
    margin: var(--space-5) 0;
    font-style: italic;
  }
</style>
