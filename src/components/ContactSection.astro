---
import type { Lang } from '../i18n';
import { t } from '../i18n';
import { siteConfig, web3formsEndpoint, whatsappUrl } from '../config/site';
import SelectedServicesBadges from './SelectedServicesBadges.tsx';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const d = t(lang);

const labels = {
  audit:   d.services.items.audit.title,
  web:     d.services.items.web.title,
  ads:     d.services.items.ads.title,
  systems: d.services.items.systems.title,
};
---

<section class="contact" id="kontakt" aria-labelledby="contact-title">
  <div class="inner">
    <header class="sec-head">
      <p class="t-eyebrow">{d.contact.eyebrow}</p>
      <h2 id="contact-title" class="t-h1 title">{d.contact.title}</h2>
      <p class="sub">{d.contact.sub}</p>
    </header>

    <div class="grid">
      <form
        class="form"
        action={web3formsEndpoint()}
        method="POST"
        data-form
        novalidate
      >
        {/* Web3Forms — obavezni Access Key (javan, vezan na tvoj email). */}
        <input type="hidden" name="access_key" value={siteConfig.web3forms.accessKey} />
        <SelectedServicesBadges
          client:load
          labels={labels}
          selectedTitle={d.contact.selectedTitle}
          emptyText={d.contact.selectedEmpty}
          clearText={d.contact.selectedClear}
        />

        <div class="field">
          <label for="f-name">{d.contact.fields.name}</label>
          <input id="f-name" name="name" type="text" required autocomplete="name" />
        </div>

        <div class="field">
          <label for="f-email">{d.contact.fields.email}</label>
          <input id="f-email" name="email" type="email" required autocomplete="email" />
        </div>

        <div class="field">
          <label for="f-message">{d.contact.fields.message}</label>
          <textarea id="f-message" name="message" rows="6" required></textarea>
        </div>

        {/* Web3Forms honeypot (botcheck) — skriven; bot ga označi, čovjek ne.
            Web3Forms ovakvu prijavu odbija na serveru, a JS je filtrira i lokalno. */}
        <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" class="gotcha" aria-hidden="true" />

        <input type="hidden" name="subject" value={`INVERZ — novi upit (${lang.toUpperCase()})`} />
        <input type="hidden" name="from_name" value="INVERZ web" />

        <button class="submit" type="submit" data-submit>
          <span data-submit-default>{d.contact.fields.submit}</span>
          <span data-submit-sending hidden>{d.contact.fields.sending}</span>
        </button>

        <p class="form-msg form-msg-success" role="status" data-msg-success hidden>
          {d.contact.success}
        </p>
        <p class="form-msg form-msg-error" role="alert" data-msg-error hidden>
          {d.contact.error}
        </p>
      </form>

      <aside class="alt">
        <p class="t-eyebrow">{d.contact.or}</p>
        <ul class="alt-list">
          <li><a href={`mailto:${siteConfig.contact.email}`}>{siteConfig.contact.email}</a></li>
          <li><a href={`tel:${siteConfig.contact.phoneRaw}`}>{siteConfig.contact.phone}</a></li>
          <li><a href={whatsappUrl()} target="_blank" rel="noopener">WhatsApp</a></li>
        </ul>
      </aside>
    </div>
  </div>
</section>

<script>
  // Asinkrono slanje na Formspree — bez navigacije.
  const form = document.querySelector<HTMLFormElement>('[data-form]');
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const submitBtn = form.querySelector<HTMLButtonElement>('[data-submit]');
      const sDefault  = form.querySelector<HTMLElement>('[data-submit-default]');
      const sSending  = form.querySelector<HTMLElement>('[data-submit-sending]');
      const msgOk     = form.querySelector<HTMLElement>('[data-msg-success]');
      const msgErr    = form.querySelector<HTMLElement>('[data-msg-error]');

      // Reset poruka
      if (msgOk)  msgOk.hidden  = true;
      if (msgErr) msgErr.hidden = true;

      // Osnovna validacija
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      // Honeypot zaštita (Web3Forms botcheck) — bot označi checkbox, čovjek ne.
      const botcheck = form.querySelector<HTMLInputElement>('input[name="botcheck"]');
      if (botcheck && botcheck.checked) return; // tiho ignoriraj bota

      submitBtn?.setAttribute('disabled', '');
      if (sDefault) sDefault.hidden = true;
      if (sSending) sSending.hidden = false;

      try {
        const data = new FormData(form);
        const res = await fetch(form.action, {
          method: 'POST',
          body: data,
          headers: { Accept: 'application/json' },
        });
        if (res.ok) {
          form.reset();
          // Očisti localStorage i obavijesti pickeer
          try { localStorage.removeItem('inverz_selected_services'); } catch (_) {}
          window.dispatchEvent(new CustomEvent('inverz:services-change', { detail: { ids: [] } }));
          if (msgOk) msgOk.hidden = false;
        } else {
          if (msgErr) msgErr.hidden = false;
        }
      } catch (_) {
        if (msgErr) msgErr.hidden = false;
      } finally {
        submitBtn?.removeAttribute('disabled');
        if (sDefault) sDefault.hidden = false;
        if (sSending) sSending.hidden = true;
      }
    });
  }
</script>

<style is:global>
  /* Globalni stilovi za React badges otok */
  .badges-shell {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-4);
    border: var(--border-hairline) solid rgba(255, 255, 255, 0.10);
    background: var(--color-smoked);
    margin-bottom: var(--space-2);
  }
  .badges-title {
    font-family: var(--font-body);
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin: 0;
  }
  .badges-empty {
    color: var(--color-muted);
    font-size: 0.9375rem;
    margin: 0;
  }
  .badges-list {
    list-style: none;
    margin: 0; padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .badge {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    padding: 6px 12px;
    border: var(--border-hairline) solid var(--color-fg);
    color: var(--color-fg);
    background: var(--color-bg);
    border-radius: var(--radius-xs);
  }
  .badges-clear {
    align-self: flex-start;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--color-muted);
    text-decoration: underline;
    text-underline-offset: 3px;
    background: transparent;
    border: 0;
    padding: 0;
    cursor: pointer;
    margin-top: var(--space-1);
  }
  .badges-clear:hover { color: var(--color-fg); }
</style>

<style>
  .contact {
    padding: var(--space-9) 0;
  }
  .inner {
    max-width: var(--max-content);
    margin: 0 auto;
    padding: 0 var(--page-padding-x);
    display: flex;
    flex-direction: column;
    gap: var(--space-7);
  }
  .sec-head { display: flex; flex-direction: column; gap: var(--space-3); }
  .title { max-width: 18ch; }
  .sub { color: var(--color-text); max-width: 56ch; font-size: 1.0625rem; }

  .grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: var(--space-7);
    align-items: start;
  }

  .form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .field { display: flex; flex-direction: column; gap: var(--space-2); }
  .field label {
    font-family: var(--font-body);
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .field input,
  .field textarea {
    font: inherit;
    font-family: var(--font-body);
    color: var(--color-fg);
    background: var(--color-smoked);
    border: var(--border-hairline) solid var(--color-border-strong);
    border-radius: var(--radius-xs);
    padding: 12px 14px;
    transition: border-color var(--transition-fast);
  }
  .field textarea { resize: vertical; min-height: 140px; }
  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--color-fg);
    box-shadow: none;
  }
  .field input:invalid:not(:placeholder-shown),
  .field textarea:invalid:not(:placeholder-shown) {
    border-color: var(--color-danger);
  }

  .gotcha {
    position: absolute;
    left: -9999px;
    top: -9999px;
    width: 1px; height: 1px;
    opacity: 0;
    pointer-events: none;
  }

  .submit {
    align-self: flex-start;
    margin-top: var(--space-2);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: var(--fw-medium);
    color: var(--color-fg);
    background: var(--color-smoked);
    border: var(--border-hairline) solid var(--color-fg);
    padding: 14px 28px;
    border-radius: var(--radius-xs);
    cursor: pointer;
    transition: background var(--transition-fast), color var(--transition-fast);
  }
  .submit:hover {
    background: var(--color-fg);
    color: var(--color-bg);
  }
  .submit[disabled] { opacity: 0.6; cursor: progress; }

  .form-msg {
    font-size: 0.9375rem;
    padding: var(--space-3) var(--space-4);
    border: var(--border-hairline) solid;
    border-radius: var(--radius-xs);
    margin: 0;
  }
  .form-msg-success { border-color: var(--color-fg); color: var(--color-fg); }
  .form-msg-error   { border-color: var(--color-danger); color: var(--color-danger-text); }

  .alt { display: flex; flex-direction: column; gap: var(--space-3); }
  .alt-list {
    list-style: none;
    margin: 0; padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .alt-list a {
    border-bottom: 0;
    color: var(--color-fg);
    font-size: 1rem;
  }
  .alt-list a:hover { opacity: 0.7; }

  @media (max-width: 820px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
