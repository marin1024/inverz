---
import type { Lang } from '../i18n';
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  lang: Lang;
  altUrl: string;
  title?: string;
  description?: string;
  canonical?: string;
}

const { lang, altUrl, title, description, canonical } = Astro.props;
---

<BaseLayout
  lang={lang}
  altUrl={altUrl}
  title={title}
  description={description}
  canonical={canonical}
>
  <Header lang={lang} altUrl={altUrl} />
  <main id="main">
    <slot />
  </main>
  <Footer lang={lang} altUrl={altUrl} />
</BaseLayout>
